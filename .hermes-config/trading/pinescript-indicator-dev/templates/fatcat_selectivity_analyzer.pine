//@version=6
indicator("FATCAT Selectivity Analyzer — POCKETBAMBAM + Filters", overlay=true)

// ═════════════════════════════════════════════════════════════════════════════
// PURPOSE: Test which post-filters make BAMBAM match FATCAT's selectivity.
// Layer each filter onto the base BAMBAM signal and compare signal counts
// against the target indicator on the same chart.
//
// Base Signal: 200-bar low + high volume + exhaustion delta (BAMBAM core)
// Post-Filters: cooldown, min price retracement, new-low-only, pivot, ATR
// Display: three layers (all base / post-filter / FATCAT-style)
// ═════════════════════════════════════════════════════════════════════════════

// ═══════════════ BASE SIGNAL (POCKETBAMBAM) ═══════════════
lookback        = input.int(200,     "Lookback (bars)",    minval=50,  maxval=2000, group="Base Signal")
volMult         = input.float(1.5,   "Volume Multiplier",  minval=0.5, maxval=5.0,  step=0.1, group="Base Signal")
lessRatio       = input.float(0.03,  "Less Ratio",         minval=0.001, maxval=0.1, group="Base Signal")
deltaMode       = input.string("OR", "Delta Mode", options=["OR", "AND"], group="Base Signal")

// ═══════════════ POST-FILTER TOGGLES ═══════════════
enableCooldown  = input.bool(true,  "Enable Cooldown",         group="Post-Filters")
cooldownBars    = input.int(96,     "Min Bars Between Signals", minval=1,  maxval=500, group="Post-Filters")

enablePriceGate = input.bool(false, "Enable Min Price Move",  group="Post-Filters")
minPricePct     = input.float(0.5,  "Min Price Change (%)",   minval=0.1, maxval=10.0, step=0.1, group="Post-Filters")

enableNewLow    = input.bool(false, "Require Lower Low than Last", group="Post-Filters")

enablePivot     = input.bool(false, "Enable Swing Pivot Filter", group="Post-Filters")
pivotLeft       = input.int(5,      "Pivot Left Bars",  minval=2,  maxval=20, group="Post-Filters")
pivotRight      = input.int(2,      "Pivot Right Bars", minval=1,  maxval=10, group="Post-Filters")

enableATR       = input.bool(false, "Enable ATR Min Move", group="Post-Filters")
atrPeriod       = input.int(14,     "ATR Period", minval=5, maxval=50, group="Post-Filters")
minMoveATR      = input.float(0.5,  "Min Move (× ATR)", minval=0.1, maxval=3.0, step=0.05, group="Post-Filters")

// ═══════════════ DISPLAY ═══════════════
showBase        = input.bool(true, "Show ALL base signals",     group="Display")
showFiltered    = input.bool(true, "Show post-filter signals",  group="Display")
showFATCATstyle = input.bool(true, "Show FATCAT-style signals", group="Display")

// ═══════════════ CORE SIGNAL LOGIC ═══════════════
vb = high == low ? 0 : volume * (close - low) / (high - low)
vs = high == low ? 0 : volume * (high - close) / (high - low)

// Confirmation bar mode (shift 1) — POCKETBAMBAM default
ph = high[1]
pl = low[1]
vd = vb[1] - vs[1]
bvol = vb[1] + vs[1]

top = ta.highest(ph, lookback)
btm = ta.lowest(pl, lookback)
avgVol = ta.sma(bvol, lookback)

vdRatio = math.abs(vd / bvol)
isLess = vdRatio < lessRatio
highVol = bvol > avgVol * volMult

deltaOk = deltaMode == "OR" ? (isLess or vd > 0) : (isLess and vd > 0)

rawBull = (pl <= btm) and highVol and deltaOk
baseBull = rawBull[1]    // shift to confirmation bar

// ═══════════════ COUNTERS ═══════════════
var totalBase     = 0
var totalFiltered = 0
var totalFATCAT   = 0

// ═══════════════ STATE FOR POST-FILTERS ═══════════════
var lastBaseBar   = -999
var lastFilterBar = -999
var lastFCBar     = -999
var lastBasePrice = 0.0

// -- Swing pivot --
isPivotLow = enablePivot ? (not na(ta.pivallow(pivotLeft, pivotRight))) : true

// -- ATR min move --
atrVal = ta.atr(atrPeriod)
hasMinMove = enableATR ? (high - low) > atrVal * minMoveATR : true

// -- Cooldown (from LAST base signal, not last accepted) --
cdOk = enableCooldown ? (bar_index - lastBaseBar >= cooldownBars) : true

// -- Price gate --
priceOk = true
if enablePriceGate and lastBasePrice != 0
    priceChg = math.abs((close - lastBasePrice) / lastBasePrice * 100)
    priceOk := priceChg >= minPricePct

// -- New low --
nlOk = true
if enableNewLow and lastBasePrice != 0
    nlOk := close < lastBasePrice

// -- Composite --
filterOk = cdOk and priceOk and nlOk and isPivotLow and hasMinMove

// ═══════════════ SIGNAL FIRING ═══════════════
if baseBull
    totalBase += 1
    lastBaseBar := bar_index
    lastBasePrice := close

filteredBull = baseBull and filterOk
fatcatBull = filteredBull

if filteredBull
    totalFiltered += 1
if fatcatBull
    totalFATCAT += 1

// ═══════════════ PLOTTING ═══════════════
plotshape(showBase and baseBull,      style=shape.triangleup, location=location.belowbar,
          color=color.new(color.gray, 60), size=size.tiny,   title="Base BAMBAM (all)")

plotshape(showFiltered and filteredBull, style=shape.triangleup, location=location.belowbar,
          color=color.new(color.blue, 0), size=size.small, title="Post-Filter Signal")

plotshape(showFATCATstyle and fatcatBull, style=shape.triangledown, location=location.abovebar,
          color=color.new(color.teal, 0), size=size.small, title="FATCAT-style (filtered)")

// ═══════════════ SIGNAL COUNT TABLE ═══════════════
if barstate.islast
    var t = table.new(position.top_right, 2, 4,
                      bgcolor=color.new(#111111, 85), border_color=color.new(#555555, 50))
    table.cell(t, 0, 0, "Layer",          text_color=color.white, text_size=size.small)
    table.cell(t, 1, 0, "Count",          text_color=color.white, text_size=size.small)
    table.cell(t, 0, 1, "Base BAMBAM",    text_color=color.gray,  text_size=size.small)
    table.cell(t, 1, 1, str.tostring(totalBase),     text_color=color.gray,  text_size=size.small)
    table.cell(t, 0, 2, "Post-Filter",    text_color=color.blue,  text_size=size.small)
    table.cell(t, 1, 2, str.tostring(totalFiltered), text_color=color.blue,  text_size=size.small)
    table.cell(t, 0, 3, "FATCAT-style",   text_color=color.teal,  text_size=size.small)
    table.cell(t, 1, 3, str.tostring(totalFATCAT),   text_color=color.teal,  text_size=size.small)

alertcondition(fatcatBull, title="FATCAT-style Entry",
               message="Long Signal @ {{close}}")
